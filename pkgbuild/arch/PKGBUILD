# Maintainer: Jussi Nokelainen <jussinoke@gmail.com>
pkgname='cldl-git'
pkgver=r74.cb591c9
pkgrel=1
pkgdesc='Directory based cli todo lists'
arch=('x86_64')
url="https://github.com/jussinokelainen/cldl"
license=('GPL-3.0-only')
depends=('glibc' 'less')
makedepends=('git' 'go')
source=("$pkgname::git+https://github.com/jussinokelainen/cldl.git")
options=('!debug')
sha256sums=('SKIP')

pkgver() {
	cd "$pkgname"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
	cd "$pkgname"
	make build
}

package() {
	cd "$pkgname"
	make DESTDIR="$pkgdir" install
}

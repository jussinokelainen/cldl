pkgname=cldl
version=@VERSION@
revision=1
hostmakedepends="git go"
makedepends=""
depends="less"
short_desc="CLI Todo lists."
maintainer="Jussi Nokelainen <jussinoke@gmail.com>"
license="MIT"
homepage="https://github.com/jussinokelainen/cldl"
nopie=yes

do_fetch() {
    git clone "https://github.com/jussinokelainen/cldl.git" "$wrksrc"
}

do_build() {
    cd "$wrksrc"
    make build
}

do_install() {
    cd "$wrksrc"
    make DESTDIR="$DESTDIR" install
}
